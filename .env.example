SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SERVICE_SECRET_KEY=
MAX_PDF_SIZE_MB=50
OCR_CONFIDENCE_THRESHOLD=0.6
RENDER_EXTERNAL_URL=

# Logging: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Force UTF-8 output (required on Windows, harmless on Linux/Render)
PYTHONUTF8=1

# CORS: comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ROBIN integration — wire newspaper articles into the correct client/source
# Get these UUIDs from the ROBIN Supabase dashboard (clients / sources tables)
ROBIN_CLIENT_ID=
NEWSPAPER_SOURCE_ID=

# Tier-3 login credentials
HINDU_EMAIL=
HINDU_PASSWORD=

# Comma-separated source names to limit scraping, or "all"
ACTIVE_SOURCES=all
